# Athena Preview — compatible with the existing Sematic client variables.
ATHENA_MODE=mock
ATHENA_BASE_URL=https://api.preview.platform.athenahealth.com
NEXT_PUBLIC_ATHENA_CLIENT_ID_2_LEG=
ATHENA_CLIENT_SECRET_2_LEG=
ATHENA_PRACTICE_ID=1959870
# Dedicated synthetic Preview record used by the hackathon golden path.
ATHENA_DEPARTMENT_ID=150
ATHENA_DEMO_PATIENT_ID=946985
ATHENA_DEMO_APPOINTMENT_ID=2589077

# Keep disabled for the hackathon scaffold. Live writes also require an
# authenticated, server-side run/approval record before production use.
ATHENA_WRITEBACK_ENABLED=false

# Claude is optional; fixtures keep the golden path deterministic.
AGENT_MODE=mock
ANTHROPIC_API_KEY=
# Sonnet handles both free-form bilingual interpretation and the clinician handoff.
ANTHROPIC_INTERPRETATION_MODEL=claude-sonnet-5
ANTHROPIC_MODEL=claude-sonnet-5
